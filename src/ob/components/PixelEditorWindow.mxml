<?xml version="1.0" encoding="utf-8"?>
<mg:TitleWindow xmlns:fx="http://ns.adobe.com/mxml/2009"
    xmlns:s="library://ns.adobe.com/flex/spark"
    xmlns:mx="library://ns.adobe.com/flex/mx"
    xmlns:mg="library://ns.mignari.com/mg"
    xmlns:ob="ob.components.*"
    width="500" height="560" fontSize="11"
    title="Pixel Editor" creationComplete="creationCompleteHandler(event)">

    <fx:Script>
        <![CDATA[
            import flash.display.BitmapData;
            import flash.events.Event;
            import flash.utils.ByteArray;

            import mx.events.FlexEvent;

            import com.mignari.utils.DialogDetail;

            private var m_source:BitmapData;
            private var m_detail:uint = DialogDetail.CANCEL;

            public function get detail():uint
            {
                return m_detail;
            }

            public function set source(value:BitmapData):void
            {
                if (m_source)
                    m_source.dispose();
                m_source = value ? value.clone() : null;
            }

            public function get pixels():ByteArray
            {
                if (!pixelCanvas.bitmapData)
                    return null;
                return pixelCanvas.bitmapData.getPixels(pixelCanvas.bitmapData.rect);
            }

            private function creationCompleteHandler(event:FlexEvent):void
            {
                pixelCanvas.bitmapData = m_source;
                updateColor();
            }

            private function updateColor():void
            {
                pixelCanvas.color = (uint(alphaStepper.value) << 24) | colorPicker.selectedColor;
            }

            private function colorPickedHandler(event:Event):void
            {
                var color:uint = pixelCanvas.color;
                alphaStepper.value = color >>> 24;
                colorPicker.selectedColor = color & 0xFFFFFF;
            }

            private function applyHandler():void
            {
                m_detail = DialogDetail.OK;
                close();
            }
        ]]>
    </fx:Script>

    <mg:layout><s:VerticalLayout/></mg:layout>

    <s:VGroup width="100%" height="100%" padding="8" gap="8" horizontalAlign="center">
        <s:HGroup width="100%" verticalAlign="middle" horizontalAlign="center" gap="5">
            <s:Button label="Pencil" click="pixelCanvas.tool = PixelCanvas.TOOL_PENCIL"/>
            <s:Button label="Eraser" click="pixelCanvas.tool = PixelCanvas.TOOL_ERASER"/>
            <s:Button label="Picker" click="pixelCanvas.tool = PixelCanvas.TOOL_PICKER"/>
            <s:Button label="Undo" click="pixelCanvas.undo()"/>
            <s:Button label="Redo" click="pixelCanvas.redo()"/>
            <s:Button label="Clear" click="pixelCanvas.clearPixels()"/>
        </s:HGroup>
        <s:HGroup verticalAlign="middle">
            <s:Label text="Color"/>
            <mx:ColorPicker id="colorPicker" selectedColor="0xFFFFFF" change="updateColor()"/>
            <s:Label text="Alpha"/>
            <s:NumericStepper id="alphaStepper" minimum="0" maximum="255" value="255" width="80" change="updateColor()"/>
        </s:HGroup>
        <s:Scroller width="100%" height="100%" horizontalScrollPolicy="auto" verticalScrollPolicy="auto">
            <s:Group>
                <ob:PixelCanvas id="pixelCanvas" select="colorPickedHandler(event)"/>
            </s:Group>
        </s:Scroller>
    </s:VGroup>

    <s:BorderContainer width="100%" skinClass="com.mignari.skins.PixeledBorderContainerSkin">
        <s:layout><s:HorizontalLayout padding="8" gap="8" horizontalAlign="right"/></s:layout>
        <s:Button label="Apply" click="applyHandler()"/>
        <s:Button label="Cancel" click="close()"/>
    </s:BorderContainer>
</mg:TitleWindow>
